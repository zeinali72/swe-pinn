{
  "name": "jax-ml-workspace",
  "containerName": "jax-ml-workspace",
  "shutdownAction": "none",

  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },

  "envFile": ["devcontainer.env"],

  // REMOVED: "ghcr.io/anthropics/devcontainer-features/claude-code:1.0"
  // That feature installs via npm, which causes the "Interrupted" bug.

  "containerEnv": {
    "LD_LIBRARY_PATH": "/usr/local/cuda/lib64:${containerEnv:LD_LIBRARY_PATH}",
    "CLAUDE_CONFIG_DIR": "/root/.claude",
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },

  "runArgs": [
    "--gpus=all",
    "--restart", "unless-stopped",
    "--shm-size=2gb"
  ],

  "mounts": [
    {
      "source": "${localEnv:HOME}/.claude",
      "target": "/root/.claude",
      "type": "bind"
    }
  ],

  "postCreateCommand": "mkdir -p /root/.claude && echo '{\"hasCompletedOnboarding\":true,\"installMethod\":\"native\"}' > /root/.claude/.claude.json && ln -sf /root/.claude/.claude.json /root/.claude.json && curl -fsSL https://claude.ai/install.sh | bash && ln -sf /root/.local/bin/claude /usr/local/bin/claude || true",
  "postAttachCommand": "cp /root/.claude/.credentials.json /root/.claude/.credentials.json.bak 2>/dev/null || true",

  "workspaceFolder": "/workspace",

  "remoteUser": "root",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.shellIntegration.enabled": false
      }
    }
  }
}