# Optuna remote storage credentials (PostgreSQL / Neon).
# Copy this file to .env and fill in values when using remote storage.
OPTUNA_DB_USER=your_username
OPTUNA_DB_PASSWORD=your_password
OPTUNA_DB_HOST=your_host
OPTUNA_DB_NAME=your_database
OPTUNA_DB_SSLMODE=require
# OPTUNA_DB_PORT=5432
# OPTUNA_DB_OPTIONS=channel_binding=require
